# Slate Health — Backend Environment Variables
# Copy this file to .env and adjust values for your environment.
#
#   cp .env.example .env
#
# All variables use the SLATE_ prefix (pydantic-settings convention).

# ── Database ──────────────────────────────────────────────────────────
# PostgreSQL connection URL.  The default expects a local PG instance
# with a "slate" role and "slate_health" database.
#
# FIRST-TIME SETUP (pick one):
#
#   Option A — Docker Compose (recommended, zero manual DB setup):
#     docker compose up -d postgres   # from project root
#     # or: make db-init-docker       # from project root
#
#   Option B — Local PostgreSQL + Makefile:
#     make db-init                    # from project root; creates role + DB
#     make db-migrate                 # runs alembic upgrade head
#
#   Option C — Local PostgreSQL manual setup:
#     createuser -s slate
#     createdb -O slate slate_health
#     # or via psql:
#     #   CREATE ROLE slate WITH LOGIN PASSWORD 'slate';
#     #   CREATE DATABASE slate_health OWNER slate;
#
# Then run migrations:
#   python -m alembic upgrade head    # from backend/ directory
#
# If you see "role 'slate' does not exist", run Option A, B, or C above first.
#
SLATE_DATABASE_URL=postgresql+asyncpg://slate:slate@localhost:5432/slate_health

# Test database (used by pytest — defaults to SQLite, no setup needed)
SLATE_TEST_DATABASE_URL=sqlite+aiosqlite:///./test.db

# ── Security ──────────────────────────────────────────────────────────
# JWT signing key — MUST be at least 32 characters.
# Generate one with:  python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SLATE_SECRET_KEY=change-me-in-production-use-at-least-32-bytes!

# ── Server ────────────────────────────────────────────────────────────
SLATE_HOST=0.0.0.0
SLATE_PORT=8000
SLATE_DEBUG=false

# ── Temporal ──────────────────────────────────────────────────────────
SLATE_TEMPORAL_ADDRESS=localhost:7233
SLATE_TEMPORAL_NAMESPACE=default
SLATE_TEMPORAL_TASK_QUEUE=slate-health-agents

# ── FHIR ──────────────────────────────────────────────────────────────
# Base URL of the FHIR R4 server (leave empty to use mock data in dev)
SLATE_FHIR_BASE_URL=

# ── OIG Exclusion List ────────────────────────────────────────────────
# When set, credentialing agent queries the real OIG LEIE API.
# Leave empty to use mock provider in dev/test.
SLATE_OIG_API_BASE_URL=

# ── Mock fallback ─────────────────────────────────────────────────────
# Allow mock/fallback data when external services are unreachable.
# Set to true for local development; MUST be false in production.
SLATE_ALLOW_MOCK_FALLBACK=true

# ── Frontend ──────────────────────────────────────────────────────────
SLATE_FRONTEND_URL=http://localhost:3000/login

# ── SSO / SAML 2.0 ───────────────────────────────────────────────────
SLATE_SAML_SP_ENTITY_ID=https://slate-health.example.com/saml/metadata
SLATE_SAML_SP_ACS_URL=http://localhost:8000/api/v1/auth/callback/saml
SLATE_SAML_IDP_ENTITY_ID=
SLATE_SAML_IDP_SSO_URL=
SLATE_SAML_IDP_X509_CERT=
SLATE_SAML_IDP_METADATA_URL=

# ── SSO / OIDC ────────────────────────────────────────────────────────
SLATE_OIDC_CLIENT_ID=
SLATE_OIDC_CLIENT_SECRET=
SLATE_OIDC_DISCOVERY_URL=
SLATE_OIDC_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback/oidc
SLATE_OIDC_SCOPES=openid email profile

# ── SSO / Role Mapping ───────────────────────────────────────────────
SLATE_SSO_ROLE_ATTRIBUTE=role
SLATE_SSO_ADMIN_VALUES=admin,administrator
SLATE_SSO_REVIEWER_VALUES=reviewer,staff,clinician

# ── Database Connection Pool ─────────────────────────────────────────
SLATE_DB_POOL_SIZE=10
SLATE_DB_MAX_OVERFLOW=20
SLATE_DB_POOL_TIMEOUT=30
SLATE_DB_POOL_RECYCLE=1800

# ── Rate Limiting ────────────────────────────────────────────────────
SLATE_RATE_LIMIT_MAX_REQUESTS=100
SLATE_RATE_LIMIT_WINDOW_SECONDS=60
# Redis URL for distributed rate limiting (leave empty for in-memory)
SLATE_RATE_LIMIT_REDIS_URL=

# ── Logging ──────────────────────────────────────────────────────────
SLATE_LOG_FORMAT=json
SLATE_LOG_LEVEL=INFO
