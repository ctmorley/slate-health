# =============================================================================
# Slate Health — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# All SLATE_* variables are loaded by the backend via pydantic-settings.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
SLATE_APP_NAME="Slate Health"
SLATE_DEBUG=false

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# PostgreSQL connection string (asyncpg driver).
# In docker-compose.prod.yml this is constructed from POSTGRES_* vars below,
# but you can override it directly here.
#
# LOCAL DEV SETUP (if not using Docker Compose):
#   1. Ensure PostgreSQL is running locally.
#   2. Run:  make db-init        (creates "slate" role and "slate_health" database)
#   3. Run:  make db-migrate     (applies Alembic migrations)
#   4. Or use Docker:  make db-init-docker  (handles both steps automatically)
#
SLATE_DATABASE_URL="postgresql+asyncpg://slate:CHANGE_ME@postgres:5432/slate_health"

# Postgres container credentials (used by docker-compose.yml / docker-compose.prod.yml)
POSTGRES_USER=slate
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=slate_health

# Test database (only used in test mode — safe to leave as default)
# SLATE_TEST_DATABASE_URL="sqlite+aiosqlite:///./test.db"

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# IMPORTANT: Generate a strong random secret of at least 32 characters.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SLATE_SECRET_KEY=CHANGE_ME_GENERATE_A_STRONG_SECRET_KEY

# JWT settings
SLATE_JWT_ALGORITHM=HS256
SLATE_JWT_EXPIRY_MINUTES=30

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
SLATE_HOST=0.0.0.0
SLATE_PORT=8000

# -----------------------------------------------------------------------------
# Temporal
# -----------------------------------------------------------------------------
SLATE_TEMPORAL_ADDRESS=temporal:7233
SLATE_TEMPORAL_NAMESPACE=default
SLATE_TEMPORAL_TASK_QUEUE=slate-health-agents

# -----------------------------------------------------------------------------
# FHIR
# -----------------------------------------------------------------------------
# Base URL for the FHIR server. Leave empty to disable live FHIR queries.
SLATE_FHIR_BASE_URL=

# -----------------------------------------------------------------------------
# External APIs
# -----------------------------------------------------------------------------
# OIG LEIE exclusion-list API base URL. When set, the credentialing agent
# queries the real OIG LEIE download/API and SAM.gov. When empty, falls back
# to MockOIGExclusionProvider (dev/test only).
SLATE_OIG_API_BASE_URL=

# Allow mock/fallback data when external services (FHIR, NPPES, OIG) are
# unreachable. Set to true ONLY in dev/test environments — production should
# keep this false to surface real failures.
SLATE_ALLOW_MOCK_FALLBACK=false

# -----------------------------------------------------------------------------
# SSO — SAML 2.0
# -----------------------------------------------------------------------------
SLATE_SAML_SP_ENTITY_ID=https://slate-health.example.com/saml/metadata
SLATE_SAML_SP_ACS_URL=https://slate-health.example.com/api/v1/auth/callback/saml
SLATE_SAML_IDP_ENTITY_ID=
SLATE_SAML_IDP_SSO_URL=
SLATE_SAML_IDP_X509_CERT=
SLATE_SAML_IDP_METADATA_URL=

# -----------------------------------------------------------------------------
# SSO — OIDC
# -----------------------------------------------------------------------------
SLATE_OIDC_CLIENT_ID=
SLATE_OIDC_CLIENT_SECRET=
SLATE_OIDC_DISCOVERY_URL=
SLATE_OIDC_REDIRECT_URI=https://slate-health.example.com/api/v1/auth/callback/oidc
SLATE_OIDC_SCOPES="openid email profile"

# -----------------------------------------------------------------------------
# SSO — Role Mapping
# -----------------------------------------------------------------------------
# IdP attribute name that carries the user's role.
SLATE_SSO_ROLE_ATTRIBUTE=role
# Comma-separated IdP attribute values that map to admin role.
SLATE_SSO_ADMIN_VALUES="admin,administrator"
# Comma-separated IdP attribute values that map to reviewer role.
SLATE_SSO_REVIEWER_VALUES="reviewer,staff,clinician"
# Any value not matching admin or reviewer maps to "viewer".

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Sliding window rate limiter (per client IP).
# Adjust based on expected traffic patterns and API usage.
SLATE_RATE_LIMIT_MAX_REQUESTS=100
SLATE_RATE_LIMIT_WINDOW_SECONDS=60
# Redis URL for distributed rate limiting. REQUIRED for multi-replica prod
# deployments (docker-compose.prod.yml uses 2 backend replicas).
# Leave empty for single-instance / development (uses in-memory counter).
SLATE_RATE_LIMIT_REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Database Connection Pool
# -----------------------------------------------------------------------------
# SQLAlchemy async engine pool tuning. Adjust based on expected concurrency
# and the number of backend replicas.
SLATE_DB_POOL_SIZE=10
SLATE_DB_MAX_OVERFLOW=20
SLATE_DB_POOL_TIMEOUT=30
SLATE_DB_POOL_RECYCLE=1800

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log format: "json" for structured JSON, "text" for human-readable output.
SLATE_LOG_FORMAT=json
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
SLATE_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
# URL the backend uses for SSO callback redirects.
SLATE_FRONTEND_URL=https://slate-health.example.com/login

# -----------------------------------------------------------------------------
# CI / Release Gate
# -----------------------------------------------------------------------------
# These variables control release-gate test behaviour in CI pipelines.
# They are NOT needed for local development.
#
# CI=true                — Enables CI-mode release-gate checks in pytest hooks.
# DOCKER_AVAILABLE=1     — Hard-fails CI if PostgreSQL migration tests skip.
# DOCKER_E2E=1           — Enables Docker Compose E2E tests (real HTTP, not ASGI).
# BACKEND_URL            — Docker E2E target URL (default: http://localhost:8000).
#
# To run the full release verification:
#   make test-release       (from project root)
#   ./scripts/release-verify.sh
#
# CI=true
# DOCKER_AVAILABLE=1
# DOCKER_E2E=1
# BACKEND_URL=http://localhost:8000
